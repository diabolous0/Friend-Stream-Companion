{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenCrew",
  "version": "0.1.0",
  "identifier": "app.screencrew.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "ScreenCrew",
        "width": 1100,
        "height": 760,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
