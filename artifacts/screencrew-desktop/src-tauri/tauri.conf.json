{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LynxDock",
  "version": "0.1.1",
  "identifier": "app.lynxdock.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LynxDock",
        "url": "index.html",
        "width": 1100,
        "height": 760,
        "minWidth": 480,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
