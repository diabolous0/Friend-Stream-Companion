# ScreenCrew self-hosting — copy this to `.env` and edit, then run docker compose.
#
#   cp .env.example .env
#   docker compose up -d --build
#
# Docker Compose reads this file automatically.

# Sign auth tokens. ALWAYS set a long random value in production:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Display name shown to your community.
SERVER_NAME=My LynxDock

# Server access and ownership.
PORT=8080
REGISTRATION=invite
ADMIN_PASSWORD=change-me-to-a-long-random-admin-password
MAX_USERS=100

# ─── Optional: bundled TURN relay (for screen sharing across the internet) ────
# Only needed if friends behind strict home routers can't see each other's
# screens. Start it with:  docker compose --profile turn up -d --build
#
# The public IP or hostname friends use to reach THIS machine (e.g. your home
# public IP, or a DNS name pointing at it). Used by coturn and the TURN URL.
TURN_PUBLIC_HOST=
# What the server advertises to clients. Usually turn:<TURN_PUBLIC_HOST>:3478
TURN_URL=
# A username and a long random password. These must match on both the relay and
# what the server advertises — Compose uses the same values for both.
TURN_USERNAME=screencrew
TURN_CREDENTIAL=change-me-to-a-long-random-turn-password
